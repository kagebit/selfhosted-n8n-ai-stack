# ========================
# n8n Configuration
# ========================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_user
N8N_BASIC_AUTH_PASSWORD=your_password

# ========================
# Webhook (Tailscale Funnel URL)
# ========================
# These are set automatically by tailscale_config.sh
WEBHOOK_URL=https://your-machine.tail-net.ts.net
WEBHOOK_TUNNEL_URL=https://your-machine.tail-net.ts.net

# ========================
# Timezone
# ========================
GENERIC_TIMEZONE=Europe/Madrid

# ========================
# Database connection (Postgres RAG)
# ========================
# These variables tell n8n to use PostgreSQL instead of SQLite.
# DB_POSTGRESDB_HOST must match the container_name of your Postgres RAG service.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=Postgres_RAG
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=your_user
DB_POSTGRESDB_PASSWORD=your_password
DB_POSTGRESDB_DATABASE=your_db

# ========================
# Optional: Shared volume paths (uncomment in docker-compose.yml to use)
# ========================
# WHISPER_FILES_PATH=/path/to/your/whisper/files
# RAG_SHARED_PATH=/path/to/your/rag/documents
