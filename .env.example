# ============================================================
# selfhosted-n8n-ai-stack — Global Environment Reference
# ============================================================
# This file is a REFERENCE ONLY. Each service reads its own
# .env file located at services/<service>/.env
#
# Copy the relevant sections to each service's .env file,
# or let the install script handle it automatically.
# ============================================================

# ========================
# n8n  →  services/n8n/.env
# ========================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_user
N8N_BASIC_AUTH_PASSWORD=your_password

# Webhook URLs — set automatically by tailscale_config.sh
WEBHOOK_URL=https://your-machine.tail-net.ts.net
WEBHOOK_TUNNEL_URL=https://your-machine.tail-net.ts.net

GENERIC_TIMEZONE=Europe/Madrid

# n8n database connection (points to Postgres RAG container)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=Postgres_RAG
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=your_user
DB_POSTGRESDB_PASSWORD=your_password
DB_POSTGRESDB_DATABASE=your_db

# ========================
# PostgreSQL RAG  →  services/postgres-rag/.env
# ========================
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db

# ========================
# PostgreSQL Vector  →  services/postgres-vector/.env
# ========================
# Use different credentials than RAG to keep them isolated
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db
